<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <TinyCSharpEnabled Condition="'$(TinyCSharpEnabled)' == ''">true</TinyCSharpEnabled>
  </PropertyGroup>

  <ItemGroup Condition="'$(TinyCSharpEnabled)' == 'true'">
    <TinyCSharpSource Include="**/*.tcs" Exclude="bin/**;obj/**" />
  </ItemGroup>

  <Target Name="TinyCSharpCompile" BeforeTargets="CoreCompile" Condition="'$(TinyCSharpEnabled)' == 'true'">
    <Exec Command="dotnet run --project &quot;$(MSBuildThisFileDirectory)..\src\TinyCSharp.Compiler\TinyCSharp.Compiler.csproj&quot; -- compile &quot;$(MSBuildProjectFullPath)&quot;" />
  </Target>

  <Target Name="RemoveOwnedGeneratedFiles" BeforeTargets="CoreCompile" Condition="'$(TinyCSharpEnabled)' == 'true'">
    <ItemGroup>
      <Compile Remove="@(TinyCSharpSource->'%(RootDir)%(Directory)%(Filename).cs')" />
    </ItemGroup>
  </Target>

  <Target Name="IncludeGeneratedCsFiles" AfterTargets="TinyCSharpCompile" Condition="'$(TinyCSharpEnabled)' == 'true'">
    <ItemGroup>
      <Compile Include="@(TinyCSharpSource->'%(RootDir)%(Directory)%(Filename).cs')" />
    </ItemGroup>
  </Target>
</Project>
